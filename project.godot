[layer_names]

3d_physics/layer_1="vehicles"
3d_physics/layer_2="projectiles"
3d_physics/layer_3="terrain"
3d_physics/layer_4="water"
3d_physics/layer_5="obstacles"

[rendering]

renderer/rendering_method="gl_compatibility"
anti_aliasing/quality/msaa_3d=2
environment/defaults/default_clear_color=Color(0.1, 0.1, 0.15, 1)
